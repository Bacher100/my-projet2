<AnchorPane xmlns:fx="http://javafx.com/fxml/1" 
    prefHeight="300.0" prefWidth="400.0">
    <Label layoutX="14.0" layoutY="14.0" text="User Registration"/> 
    <TextField fx:id="nameField" layoutX="14.0" layoutY="50.0" promptText="Name"/> 
    <TextField fx:id="emailField" layoutX="14.0" layoutY="100.0" promptText="Email"/> 
    <TextField fx:id="phoneField" layoutX="14.0" layoutY="150.0" promptText="Phone"/> 
    <PasswordField fx:id="passwordField" layoutX="14.0" layoutY="200.0" promptText="Password"/> 
    <ComboBox fx:id="roleComboBox" layoutX="14.0" layoutY="250.0"> 
        <items>
            <String fx:value="User"/> 
            <String fx:value="Admin"/> 
        </items>
    </ComboBox>
    <Button layoutX="150.0" layoutY="300.0" text="Register"/> 
</AnchorPane>